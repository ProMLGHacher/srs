# Для docker compose: LAN-IP хоста с Docker (WebRTC UDP 8000)
# SRS_CANDIDATE_IP=192.168.1.10

# Порт приложения на хосте (внутри контейнера приложение слушает 3001)
# APP_HOST_PORT=3080

# Локальная разработка front_app (опционально, если API не на том же origin)
# VITE_SIGNAL_URL=
# VITE_SIGNAL_WS=
