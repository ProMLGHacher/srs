# Для docker compose: LAN-IP хоста с Docker (WebRTC UDP 8000)
# SRS_CANDIDATE_IP=192.168.1.10

# Порт приложения на хосте (внутри контейнера приложение слушает 3001)
# APP_HOST_PORT=3080

# Локальная разработка front_app (опционально, если API не на том же origin)
# VITE_SIGNAL_URL=
# VITE_SIGNAL_WS=

# --- voice stack: docker compose -f docker-compose.yml -f docker-compose.voice.yml up ---
# Наружу только gateway (VOICE_GATEWAY_PORT). SFU/Web без портов на хост — см. комментарии в docker-compose.voice.yml
# VOICE_GATEWAY_PORT=3091
# VOICE_PUBLIC_IP=192.168.1.10
# Редко нужно: VOICE_UDP_PORT_MIN / VOICE_UDP_PORT_MAX — UDP внутри контейнера для Pion (дефолт 10000–10100)
# Для звука из браузера на хосте без проброса UDP — TURN (VITE_ICE_SERVERS_JSON в voice_web/.env.example)
